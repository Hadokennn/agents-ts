{
  "version": "0.2.0",
  "configurations": [
    {
      // 调试入口程序（交互式 readline，必须用集成终端才能键盘输入）
      "name": "Debug index.ts",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--import", "tsx"],
      "program": "${workspaceFolder}/src/index.ts",
      // "args": ["--continue"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "sourceMaps": true,
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
      "envFile": "${workspaceFolder}/.env"
    },
    {
      // 调试当前打开的任意 .ts 文件
      "name": "Debug current file",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--import", "tsx"],
      "program": "${file}",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "sourceMaps": true,
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
      "envFile": "${workspaceFolder}/.env"
    }
  ]
}
