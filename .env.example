# DeepSeek API Key (可选，不设置则使用 Mock Model)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# GitHub Personal Access Token (可选，用于 GitHub MCP Server)
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_token_here

# MCP 实现选择:
# - "sdk" (默认): 使用官方 @modelcontextprotocol/sdk
# - "handwritten": 使用手写的实现
MCP_IMPLEMENTATION=sdk

# Embedding 实现选择: local | dashscope | mock
# - 不设置时：有 DASHSCOPE_API_KEY 用云(dashscope)，否则 mock（保持原行为）
# - local: 本地 GGUF 模型，离线免 key、数据不出本机（需先 pnpm add node-llama-cpp）
EMBEDDER=

# 本地 embedding 模型（仅 EMBEDDER=local 时生效）：HF GGUF URI 或本地 .gguf 路径
# 默认 hf:Qwen/Qwen3-Embedding-0.6B-GGUF/Qwen3-Embedding-0.6B-Q8_0.gguf（中文强）
LOCAL_EMBED_MODEL=

# DashScope API Key（EMBEDDER=dashscope，或未显式设置 EMBEDDER 时启用云 embedding）
DASHSCOPE_API_KEY=your_dashscope_api_key_here
