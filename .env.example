# DeepSeek API Key (可选，不设置则使用 Mock Model)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# GitHub Personal Access Token (可选，用于 GitHub MCP Server)
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_token_here

# MCP 实现选择:
# - "sdk" (默认): 使用官方 @modelcontextprotocol/sdk
# - "handwritten": 使用手写的实现
MCP_IMPLEMENTATION=sdk
